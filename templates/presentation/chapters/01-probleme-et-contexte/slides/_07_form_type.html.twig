{% import 'presentation/_macros.html.twig' as ui %}
{% import 'presentation/chapters/01-probleme-et-contexte/_macros.html.twig' as card %}

<section data-slide-id="01-form-type">
    {{ ui.slide_header('1.5', 'Form Type détourné', 'Quand le Form devient un "widget riche"') }}

<pre><code class="language-php">final class TagPickerType extends AbstractType
{
    public function configureOptions(OptionsResolver $resolver): void
    {
        $resolver->setDefaults([
            'choices' => [],
            'multiple' => true,
            'attr' => ['class' => 'tag-picker'],
        ]);
    }

    public function getParent(): string
    {
        return ChoiceType::class;
    }
}</code></pre>

    {{ card.pros_cons(
        [
            'Contrat de props via <code>OptionsResolver</code>',
            'Logique PHP encapsulée · template via <code>form_theme</code>',
        ],
        [
            '<strong>Uniquement pour des champs de formulaire</strong> — inutile pour Card, Modal, Sidebar',
            'Machinerie pensée pour la collecte de données, pas l\'affichage',
            'Couplage fort au cycle bind / submit / validate',
        ]
    ) }}

    {{ card.verdict('Détournement qui marche dans un cas très spécifique — pas un modèle composant généraliste.') }}
</section>
