{% import 'presentation/_macros.html.twig' as ui %}
{% import 'presentation/chapters/01-probleme-et-contexte/_macros.html.twig' as card %}

<section data-slide-id="01-form-type">
    {{ ui.slide_header('1.5', 'Form Type comme composant', 'Réutiliser la machinerie formulaire pour de l\'UI générique') }}

    <p>
        Un <code>AbstractType</code> a deux atouts proches d'un composant :
        un contrat d'entrée via <code>OptionsResolver</code> et un template isolé via <code>form_theme</code>.
        Certaines équipes l'ont utilisé pour rendre des widgets non-formulaires.
    </p>

    {{ card.pros_cons(
        [
            'Contrat de props via <code>OptionsResolver</code>',
            'Template dédié via <code>form_theme</code>',
        ],
        [
            'Réservé aux champs de saisie — inutilisable pour Card, Modal, Sidebar…',
            'Tout composant doit vivre dans un <code>form_start / form_end</code>',
            'Machinerie pensée pour bind / validate / submit, pas pour l\'affichage',
        ]
    ) }}

    {{ card.verdict('Fonctionne pour un widget de saisie. Ne fonctionne pas comme modèle composant généraliste.') }}
</section>
