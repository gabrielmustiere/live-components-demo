{% import 'presentation/_macros.html.twig' as ui %}
{% import 'presentation/chapters/01-probleme-et-contexte/_macros.html.twig' as card %}

<section data-slide-id="01-render-controller">
    {{ ui.slide_header('1.3', 'render(controller(…))') }}

    <div class="code-split">
        <div class="code-split__col">
            <h3>Appel Twig</h3>
<pre><code class="language-twig">{% verbatim %}{# Dans le layout principal #}
{{ render(controller(
    'App\\Controller\\CartController::miniCart'
)) }}{% endverbatim %}</code></pre>
        </div>

        <div class="code-split__col">
            <h3>Contrôleur dédié</h3>
<pre><code class="language-php">public function miniCart(
    CartRepository $carts,
    Security $security,
): Response {
    $cart = $carts->findCurrentFor($security->getUser());

    return $this->render('cart/_mini_cart.html.twig', [
        'itemCount' => $cart->count(),
        'total' => $cart->total(),
    ]);
}</code></pre>
        </div>
    </div>

    {{ card.pros_cons(
        [
            '<strong>Vraie logique PHP</strong> : DI, services, repositories',
            'Cache indépendant possible (ESI + Varnish)',
        ],
        [
            '<strong>Sous-requête HTTP interne</strong> à chaque rendu — event subscribers rejoués',
            'Coût qui explose sur une page à 10–15 fragments',
            'DX médiocre : route + action + template dispersés',
        ]
    ) }}
</section>
