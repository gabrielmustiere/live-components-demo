{% import 'presentation/_macros.html.twig' as ui %}
{% import 'presentation/chapters/01-probleme-et-contexte/_macros.html.twig' as card %}

<section data-slide-id="01-twig-extension">
    {{ ui.slide_header('2.4', 'Twig extension', 'Une fonction PHP qui génère du HTML') }}

<pre><code class="language-php">final class UiExtension extends AbstractExtension
{
    public function getFunctions(): array
    {
        return [
            new TwigFunction('badge', [$this, 'renderBadge'], ['is_safe' => ['html']]),
        ];
    }

    public function renderBadge(string $label, string $color = 'gray'): string
    {
        return sprintf(
            '&lt;span class="badge badge-%s"&gt;%s&lt;/span&gt;',
            htmlspecialchars($color, ENT_QUOTES, 'UTF-8'),
            htmlspecialchars($label, ENT_QUOTES, 'UTF-8'),
        );
    }
}</code></pre>

    {{ card.pros_cons(
        [
            'Logique PHP disponible · services injectables',
            'Testable en PHPUnit standard',
        ],
        [
            '<strong>HTML en string PHP</strong> : illisible, XSS facile',
            'Pas de slots, pas de props typées, pas d\'état',
            'Explosion du namespace Twig global à chaque nouveau composant',
        ]
    ) }}

    {{ card.verdict('Bon outil pour des helpers (formater une date, transformer un slug) — mauvais outil pour un composant d\'UI.') }}
</section>
