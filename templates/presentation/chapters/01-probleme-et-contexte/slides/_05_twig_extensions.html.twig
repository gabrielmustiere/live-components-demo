{% import 'presentation/_macros.html.twig' as ui %}
{% import 'presentation/chapters/01-probleme-et-contexte/_macros.html.twig' as card %}

<section data-slide-id="01-twig-extension">
    {{ ui.slide_header('1.4', 'Twig extension', 'Idée : enregistrer une fonction Twig qui génère du HTML') }}

    <div class="code-split">
        <div class="code-split__col">
            <h3>La fonction PHP</h3>
<pre><code class="language-php">// UiExtension.php
new TwigFunction('badge', [$this, 'renderBadge'], ['is_safe' => ['html']]),

public function renderBadge(string $label, string $color = 'gray'): string
{
    return sprintf(
        '&lt;span class="badge badge-%s"&gt;%s&lt;/span&gt;',
        htmlspecialchars($color),
        htmlspecialchars($label),
    );
}</code></pre>
        </div>
        <div class="code-split__col">
            <h3>L'usage dans le template</h3>
<pre><code class="language-twig">{% verbatim %}{{ badge('Nouveau', 'green') }}
{{ badge(product.status, 'red') }}{% endverbatim %}</code></pre>

            <p>L'appel est propre… mais <strong>le markup vit dans une string PHP</strong> :</p>
            <ul>
                <li>impossible à lire / modifier sans toucher au PHP</li>
                <li>pas de slots, pas d'IDE qui autocomplète le HTML</li>
                <li>chaque nouveau composant = une nouvelle fonction dans le namespace Twig global</li>
            </ul>
        </div>
    </div>

    {{ card.verdict('Bon outil pour des helpers de formatage (date, slug, prix). Mauvais outil pour un composant d\'UI.') }}
</section>
