{% import 'presentation/_macros.html.twig' as ui %}
{% import 'presentation/chapters/01-probleme-et-contexte/_macros.html.twig' as card %}

<section data-slide-id="01-twig-macro">
    {{ ui.slide_header('2.2', 'Twig macro', 'Une fonction Twig avec paramètres nommés') }}

<pre><code class="language-twig">{% verbatim %}{# templates/macros/ui.html.twig #}
{% macro button(label, variant = 'primary', type = 'button') %}
    <button type="{{ type }}" class="btn btn-{{ variant }}">
        {{ label }}
    </button>
{% endmacro %}

{# Utilisation #}
{% import 'macros/ui.html.twig' as ui %}
{{ ui.button('Acheter', 'success') }}{% endverbatim %}</code></pre>

    {{ card.pros_cons(
        [
            '<strong>Signature explicite</strong> · valeurs par défaut',
            'Isolation totale du contexte (contrairement à <code>include</code>)',
        ],
        [
            'Toujours <strong>zéro PHP</strong> · pas de services injectables',
            'Pas de types sur les paramètres, pas d\'état',
            'Pas de <strong>slots</strong> : on ne peut pas passer un bloc Twig en paramètre',
        ]
    ) }}

    {{ card.verdict('Progrès réel, mais toujours dans le monde Twig pur. Parfait pour les primitives sans logique (bouton, badge, label).') }}
</section>
