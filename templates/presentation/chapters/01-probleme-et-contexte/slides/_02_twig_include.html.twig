{% import 'presentation/_macros.html.twig' as ui %}
{% import 'presentation/chapters/01-probleme-et-contexte/_macros.html.twig' as card %}

<section data-slide-id="01-twig-include">
    {{ ui.slide_header('1.1', 'Twig include') }}

<pre><code class="language-twig">{% verbatim %}{# templates/components/_alert.html.twig #}
<div class="alert alert-{{ type|default('info') }}">
    {{ message }}
</div>

{# Utilisation — `only` isole le contexte parent #}
{% include 'components/_alert.html.twig'
    with { type: 'error', message: 'Oops' } only %}{% endverbatim %}</code></pre>

    {{ card.pros_cons(
        [
            'Factorisation du <strong>markup répété</strong>',
            'Un seul endroit pour changer le design',
        ],
        [
            '<strong>Zéro logique PHP</strong> : le template ne sait rien faire',
            'Pas de contrat fort sur les props · faute de frappe = bug silencieux',
            'Pas d\'état · <code>only</code> oublié = fuite de contexte',
        ]
    ) }}

    {{ card.legitimate_uses([
        'Fragments purement visuels (en-tête, pied de page, snippet statique)',
        'Réutilisation locale à un groupe de templates',
    ]) }}
</section>
