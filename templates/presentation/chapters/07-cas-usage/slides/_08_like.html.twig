{% import 'presentation/_macros.html.twig' as ui %}

<section data-slide-id="07-like">
    {{ ui.slide_header('7.7', 'Exemple : quick action — bouton like', 'Mise à jour instantanée, persistance automatique') }}

    <div class="code-split">
        <div class="code-split__col">
            <h3>LikeButton.php</h3>
<pre><code class="language-php">#[AsLiveComponent]
final class LikeButton
{
    use DefaultActionTrait;

    #[LiveProp] public int  $postId;
    #[LiveProp] public int  $count;
    #[LiveProp] public bool $liked = false;

    public function __construct(
        private readonly PostRepository $posts,
        private readonly Security $security,
    ) {}

    #[LiveAction]
    public function toggle(): void
    {
        $post = $this->posts->find($this->postId);
        $user = $this->security->getUser();

        $this->liked
            ? $post->removeLike($user)
            : $post->addLike($user);

        $this->count += $this->liked ? -1 : 1;
        $this->liked  = !$this->liked;
        $this->posts->save($post);
    }
}</code></pre>
        </div>
        <div class="code-split__col">
            <h3>LikeButton.html.twig</h3>
<pre><code class="language-twig">{% verbatim %}<button {{ attributes }}
    data-action="live#action"
    data-live-action-param="toggle"
    class="{{ liked ? 'text-red-500' : 'text-gray-400' }}"
>
    ♥ {{ count }}
</button>{% endverbatim %}</code></pre>

<pre><code class="language-twig">{% verbatim %}{# Usage dans la page #}
{% for post in posts %}
    <twig:LikeButton
        :postId="post.id"
        :count="post.likesCount"
        :liked="post.isLikedBy(app.user)"
    />
{% endfor %}{% endverbatim %}</code></pre>

            <div class="legitimate">
                <h3>🎯 Ce qu'on obtient</h3>
                <ul>
                    <li>UX instantanée via DOM morphing</li>
                    <li>Persistance sans endpoint custom</li>
                    <li>Réutilisable sur toute entité</li>
                    <li>Sécurisé côté PHP, jamais exposé au client</li>
                </ul>
            </div>
        </div>
    </div>
</section>
