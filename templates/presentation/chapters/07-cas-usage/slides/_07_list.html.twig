{% import 'presentation/_macros.html.twig' as ui %}

<section data-slide-id="07-list">
    {{ ui.slide_header('7.6', 'Exemple : liste filtrable + pagination') }}

    <div class="code-split">
        <div class="code-split__col">
            <h3>ProductList.php</h3>
<pre><code class="language-php">#[AsLiveComponent]
final class ProductList
{
    use DefaultActionTrait;

    // url: true → ?search=velo&page=2 dans l'URL
    #[LiveProp(writable: true, url: true)]
    public string $search = '';

    #[LiveProp(writable: true, url: true)]
    public string $sortBy = 'name';

    #[LiveProp(writable: true, url: true)]
    public int $page = 1;

    public function getProducts(): array
    {
        return $this->products->findFiltered(
            $this->search, $this->sortBy, $this->page
        );
    }
}</code></pre>
        </div>
        <div class="code-split__col">
            <h3>Template (extrait)</h3>
<pre><code class="language-twig">{% verbatim %}<input data-model="debounce(300)|search">

<select data-model="sortBy">
    <option value="name">Nom A–Z</option>
    <option value="price_asc">Prix ↑</option>
</select>

{% for product in this.products %}
    <tr><td>{{ product.name }}</td></tr>
{% endfor %}

{# Pagination sans méthode PHP supplémentaire #}
{% for p in 1..this.totalPages %}
    <button
        data-action="live#action"
        data-live-action-param="$set(page={{ p }})"
    >{{ p }}</button>
{% endfor %}{% endverbatim %}</code></pre>
        </div>
    </div>

    <blockquote class="verdict">
        <code>url: true</code> — l'URL reflète l'état (<code>?search=velo&amp;sortBy=price_asc&amp;page=2</code>).
        Partage de lien et retour arrière fonctionnels <strong>sans une ligne de JS</strong>.
    </blockquote>
</section>
