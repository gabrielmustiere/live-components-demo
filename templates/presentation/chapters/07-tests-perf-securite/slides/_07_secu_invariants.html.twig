{% import 'presentation/_macros.html.twig' as ui %}

<section data-slide-id="07-secu-invariants">
    {{ ui.slide_header('7.6', 'Sécurité : les invariants à tenir') }}

    <div class="code-split">
        <div class="code-split__col">
            <h3>🔑 1. writable = entrée utilisateur → valider</h3>
<pre><code class="language-php">#[LiveProp(writable: true)]
#[Assert\Length(max: 120)]
public string $title = '';

#[LiveProp(writable: true)]
#[Assert\Range(min: 1, max: 100)]
public int $pageSize = 20;

#[LiveProp(writable: true)]
#[Assert\Choice(['name', 'price_asc', 'price_desc'])]
public string $sortBy = 'name';</code></pre>
        </div>
        <div class="code-split__col">
            <h3>🔑 2. non-writable = signé (fingerprint)</h3>
<pre><code class="language-php">// Client peut modifier → repartira modifiée
#[LiveProp(writable: true)]
public string $query = '';

// Client peut modifier le DOM, mais le serveur
// rejettera le payload altéré (fingerprint mismatch)
#[LiveProp]
public int $postId;</code></pre>
        </div>
    </div>

    <div class="code-split">
        <div class="code-split__col">
            <h3>🔑 3. LiveAction → #[IsGranted] comme un controller</h3>
<pre><code class="language-php">#[LiveAction]
#[IsGranted('EDIT', 'order')]
public function save(OrderRepository $orders): void { /* ... */ }

#[LiveAction]
#[IsGranted('ROLE_ADMIN')]
public function deleteAllItems(): void { /* ... */ }</code></pre>
        </div>
        <div class="code-split__col">
            <h3>🔑 4. Jamais de secret dans une LiveProp</h3>
<pre><code class="language-php">// Tout LiveProp → DOM (data-live-props-value)
// ❌ password, token, apiKey, creditCardNumber
// ❌ entité User complète (hash mdp exposé)

// ✅ stocker l'ID, recharger côté serveur
#[LiveProp]
public int $userId;</code></pre>
        </div>
    </div>

    <h3>🔑 5. Valider les #[LiveArg] d'une action</h3>
<pre><code class="language-php">#[LiveAction]
public function addToCart(
    #[LiveArg] int $productId,
    #[LiveArg] int $quantity,
): void {
    if ($quantity < 1 || $quantity > 99) {
        throw new \InvalidArgumentException('Invalid quantity');
    }
    $product = $this->products->find($productId) ?? throw new NotFoundHttpException();
    $this->cart->add($product, $quantity);
}</code></pre>
</section>
