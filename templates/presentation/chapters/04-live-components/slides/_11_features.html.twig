{% import 'presentation/_macros.html.twig' as ui %}

<section data-slide-id="04-features">
    {{ ui.slide_header('4.10', 'Ce que le bundle offre en plus') }}

    <div class="code-split">
        <div class="code-split__col">
            <h3>Loading states</h3>
<pre><code class="language-twig">{% verbatim %}<button data-action="live#action" data-live-action-param="save">
    <span data-loading="hide">Enregistrer</span>
    <span data-loading="show">Enregistrement…</span>
</button>{% endverbatim %}</code></pre>
        </div>
        <div class="code-split__col">
            <h3>Polling</h3>
<pre><code class="language-twig">{% verbatim %}<div {{ attributes }} data-poll="delay(5000)|$render">
    Notifications : {{ count }}
</div>{% endverbatim %}</code></pre>
        </div>
    </div>

    <div class="code-split">
        <div class="code-split__col">
            <h3>Emit / Listen — composants imbriqués</h3>
<pre><code class="language-php">// enfant
$this->emit('product:added', ['id' => $id]);

// parent
#[LiveListener('product:added')]
public function onAdded(#[LiveArg] int $id): void
{
    // ...
}</code></pre>
        </div>
        <div class="code-split__col">
            <h3>Hooks de cycle de vie</h3>
<pre><code class="language-php">#[PreReRender]
public function beforeRender(): void
{
    $this->lastRenderedAt = new \DateTimeImmutable();
}

// détaillé au chapitre 5</code></pre>
        </div>
    </div>

    <blockquote class="verdict">
        <strong>Loading, polling, events, hooks : tout est déjà dans le bundle.</strong>
    </blockquote>
</section>
