{% import 'presentation/_macros.html.twig' as ui %}

<section data-slide-id="04-action-binding">
    {{ ui.slide_header('4.7', 'LiveAction + data-model', 'Méthode PHP déclenchable + input lié') }}

    <div class="code-split">
        <div class="code-split__col">
            <h3>Counter.php</h3>
<pre><code class="language-php">#[AsLiveComponent]
final class Counter
{
    use DefaultActionTrait;

    #[LiveProp(writable: true)]
    public int $count = 0;

    #[LiveAction]
    public function increment(): void
    {
        $this->count++;
    }

    #[LiveAction]
    public function addToCart(
        #[LiveArg] int $productId,
        CartManager $cart,   // autowired
    ): void {
        $cart->add($productId, 1);
    }
}</code></pre>
        </div>
        <div class="code-split__col">
            <h3>Counter.html.twig</h3>
<pre><code class="language-twig">{% verbatim %}<div {{ attributes }}>
    <p>Compteur : {{ count }}</p>

    <button
        data-action="live#action"
        data-live-action-param="increment"
    >+1</button>
</div>{% endverbatim %}</code></pre>
        </div>
    </div>

    <h3>Les variantes de <code>data-model</code></h3>

<pre><code class="language-twig">{% verbatim %}<input data-model="query">                        {# re-render à chaque frappe #}
<input data-model="debounce(300)|query">            {# debounce 300 ms — recherche live #}
<input data-model="on(change)|email">               {# re-render au blur — formulaire #}
<input data-model="norender|message">               {# prop à jour, pas de re-render #}
<input data-model="contact.name">                   {# sous-propriété d'objet #}{% endverbatim %}</code></pre>
</section>
