{% import 'presentation/_macros.html.twig' as ui %}

<section data-slide-id="05-hydratation">
    {{ ui.slide_header('5.5', 'Hydratation PHP', 'Stateless serveur, stateful DOM') }}

    <div class="code-split">
        <div class="code-split__col">
            <h3>Séquence serveur</h3>
<pre><code class="language-text">1. Requête reçue
   /_components/Counter
2. Classe instanciée
   (services autowirés)
3. LiveProp hydratées
   depuis le payload JSON
4. → #[PostHydrate]
5. LiveAction exécutée
   (increment())
6. LiveProp éventuellement
   modifiées</code></pre>
        </div>
        <div class="code-split__col">
            <h3>Exemple</h3>
<pre><code class="language-php">#[AsLiveComponent]
final class Counter
{
    use DefaultActionTrait;

    #[LiveProp(writable: true)]
    public int $count = 0;

    #[PostHydrate]
    public function afterHydration(): void
    {
        // Corriger une valeur hors limites
        // avant d'exécuter l'action.
        if ($this->count &lt; 0) {
            $this->count = 0;
        }
    }

    #[LiveAction]
    public function increment(): void
    {
        $this->count++;
    }
}</code></pre>
        </div>
    </div>

    <p><small>
        Types non-scalaires (entités, DTO, VO) : <strong>Symfony Serializer</strong>.
        Surcharger avec <code>hydrateWith</code> / <code>dehydrateWith</code> — souvent indispensable pour Doctrine.
    </small></p>
</section>
