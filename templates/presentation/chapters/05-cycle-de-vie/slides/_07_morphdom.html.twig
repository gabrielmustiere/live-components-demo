{% import 'presentation/_macros.html.twig' as ui %}

<section data-slide-id="05-morphdom">
    {{ ui.slide_header('5.6', 'DOM patch : morphdom', 'HTML pur en réponse — diff appliqué nœud par nœud') }}

    <div class="pros-cons">
        <div class="pros-cons__col pros-cons__col--pros">
            <h3>✅ morphdom préserve</h3>
            <ul>
                <li>Le <strong>focus</strong> — l'input de recherche reste actif pendant la frappe</li>
                <li>La position de <strong>scroll</strong></li>
                <li>Les Stimulus controllers déjà attachés</li>
            </ul>
        </div>
        <div class="pros-cons__col pros-cons__col--cons">
            <h3>⚠️ Points d'attention</h3>
            <ul>
                <li>Listes sans <code>id</code> stable → mauvais <code>&lt;li&gt;</code> réutilisé</li>
                <li>Bibliothèques JS tierces (WYSIWYG, Leaflet) → protéger avec <code>data-live-ignore</code></li>
                <li>Animations en cours → peuvent être coupées</li>
            </ul>
        </div>
    </div>

    <div class="code-split">
        <div class="code-split__col">
            <h3>Directives morphdom</h3>
<pre><code class="language-html">&lt;!-- Jamais touché — ex: carte Leaflet --&gt;
&lt;div data-live-ignore&gt;
    &lt;div id="map"&gt;&lt;/div&gt;
&lt;/div&gt;

&lt;!-- Remplacement total (pas de diff) --&gt;
&lt;canvas data-live-replace&gt;&lt;/canvas&gt;</code></pre>
        </div>
        <div class="code-split__col">
            <h3>ProductSearch — IDs stables</h3>
<pre><code class="language-twig">{% verbatim %}{# ❌ Sans id — morphdom peut recycler #}
{# le mauvais li quand la liste change #}
{% for product in this.results %}
    <li>{{ product.name }}</li>
{% endfor %}

{# ✅ Avec id Doctrine — nœud identifiable #}
{% for product in this.results %}
    <li id="product-{{ product.id }}">
        {{ product.name }}
    </li>
{% endfor %}{% endverbatim %}</code></pre>
        </div>
    </div>
</section>
