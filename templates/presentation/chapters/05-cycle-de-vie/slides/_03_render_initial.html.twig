{% import 'presentation/_macros.html.twig' as ui %}

<section data-slide-id="05-render-initial">
    {{ ui.slide_header('5.2', 'Render initial : ProductSearch', 'L\'état sérialisé dans le DOM dès le premier chargement') }}

    <div class="code-split">
        <div class="code-split__col">
            <h3>La classe</h3>
<pre><code class="language-php">#[AsLiveComponent]
final class ProductSearch
{
    use DefaultActionTrait;

    #[LiveProp(writable: true)]
    public string $query = '';

    public function __construct(
        private readonly ProductRepository $products,
    ) {}

    public function getResults(): array
    {
        if (mb_strlen(trim($this->query)) < 2) {
            return [];
        }
        return $this->products->searchByName($this->query);
    }
}</code></pre>
        </div>
        <div class="code-split__col">
            <h3>Markup généré</h3>
<pre><code class="language-html">&lt;div
  data-controller="live"
  data-live-url-value="/_components/ProductSearch"
  data-live-props-value='{"query":""}'
  data-live-fingerprint-value="a1b2c3"
&gt;
  &lt;input
    type="search"
    data-model="debounce(300)|query"
    placeholder="Rechercher…"
  &gt;
  &lt;!-- query vide → getResults() retourne [] --&gt;
&lt;/div&gt;</code></pre>

            <p><small>
                <code>data-live-props-value</code> = état sérialisé — seule <code>$query</code> est une <code>LiveProp</code>.
                <br>
                Les résultats Doctrine <strong>ne sont pas</strong> dans le DOM — recalculés à chaque rendu.
            </small></p>
        </div>
    </div>
</section>
