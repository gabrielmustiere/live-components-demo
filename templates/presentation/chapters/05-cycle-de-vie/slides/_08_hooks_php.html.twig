{% import 'presentation/_macros.html.twig' as ui %}

<section data-slide-id="05-hooks-php">
    {{ ui.slide_header('5.8', 'Les 4 hooks PHP', 'À quel moment chacun s\'exécute') }}

    <table class="recap-table">
        <thead>
            <tr>
                <th>Hook</th>
                <th>Render initial</th>
                <th>Re-render Ajax</th>
                <th>Moment d'exécution</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td><code>#[PostMount]</code></td>
                <td>✅</td>
                <td>❌</td>
                <td>Après l'instanciation + <code>mount()</code></td>
            </tr>
            <tr>
                <td><code>#[PostHydrate]</code></td>
                <td>❌</td>
                <td>✅</td>
                <td>Après hydratation des <code>LiveProp</code></td>
            </tr>
            <tr>
                <td><code>#[PreReRender]</code></td>
                <td>❌</td>
                <td>✅</td>
                <td>Juste avant le re-render Twig</td>
            </tr>
            <tr>
                <td><code>#[PreDehydrate]</code></td>
                <td>✅</td>
                <td>✅</td>
                <td>Avant la sérialisation des props</td>
            </tr>
        </tbody>
    </table>

<pre><code class="language-php">#[AsLiveComponent]
final class ProductSearch
{
    #[LiveProp(writable: true)] public string $query = '';
    /** @var Product[] */ public array $results = [];

    #[PostMount]    public function init(): void    { $this->results = $this->load(); } // render initial
    #[PostHydrate]  public function reload(): void  { $this->results = $this->load(); } // cycle Ajax
    #[PreReRender]  public function prep(): void    { /* pagination, sort dérivé */ }
    #[PreDehydrate] public function clear(): void   { $this->results = []; }            // pas dans le DOM
}</code></pre>

    <p><small>Plusieurs hooks du même type ? Ordonnancer avec <code>#[PostHydrate(priority: 10)]</code> — priorité haute = avant.</small></p>
</section>
