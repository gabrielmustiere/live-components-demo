{% import 'presentation/_macros.html.twig' as ui %}

<section data-slide-id="05-rerender">
    {{ ui.slide_header('5.5', 'Re-render : Doctrine → Twig → DOM', 'getResults() interroge la base, Twig affiche la liste') }}

    <div class="code-split">
        <div class="code-split__col">
            <h3>ProductRepository (Doctrine)</h3>
<pre><code class="language-php">class ProductRepository extends ServiceEntityRepository
{
    public function searchByName(
        string $query,
        int $limit = 10,
    ): array {
        return $this->createQueryBuilder('p')
            ->andWhere('LOWER(p.name) LIKE :q')
            ->setParameter('q', '%'.$query.'%')
            ->orderBy('p.name', 'ASC')
            ->setMaxResults($limit)
            ->getQuery()
            ->getResult(); // Product[]
    }
}</code></pre>
        </div>
        <div class="code-split__col">
            <h3>Template ProductSearch.html.twig</h3>
<pre><code class="language-twig">{% verbatim %}<ul>
    {% for product in this.results %}
        {# id stable = morphdom recycle le nœud #}
        <li id="product-{{ product.id }}">
            <span>{{ product.name }}</span>
            <span>{{ product.price / 100 }} €</span>
        </li>
    {% else %}
        <li>Aucun résultat pour "{{ query }}"</li>
    {% endfor %}
</ul>{% endverbatim %}</code></pre>

            <blockquote class="verdict">
                <code>id="product-{{ '{{ product.id }}' }}"</code> — identifiant stable.
                Sans lui, morphdom ne sait pas quel <code>&lt;li&gt;</code> correspond à quel produit
                et peut recycler le mauvais nœud.
            </blockquote>
        </div>
    </div>
</section>
