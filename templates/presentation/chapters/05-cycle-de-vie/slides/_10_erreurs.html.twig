{% import 'presentation/_macros.html.twig' as ui %}

<section data-slide-id="05-erreurs">
    {{ ui.slide_header('5.9', 'Gestion des erreurs', 'Les erreurs métier deviennent un état — pas un 500') }}

    <div class="code-split">
        <div class="code-split__col">
            <table class="recap-table">
                <thead>
                    <tr><th>Situation</th><th>Comportement</th><th>À faire</th></tr>
                </thead>
                <tbody>
                    <tr>
                        <td>Exception dans <code>getResults()</code></td>
                        <td>500 · <code>response:error</code> JS</td>
                        <td>Attraper → stocker le message comme état</td>
                    </tr>
                    <tr>
                        <td>Violation de validation</td>
                        <td>Injection dans <code>_errors</code>, re-render</td>
                        <td><code>ValidatableComponentTrait</code></td>
                    </tr>
                    <tr>
                        <td>Conflit de fingerprint</td>
                        <td>Re-render forcé depuis le serveur</td>
                        <td>Rien — le bundle gère (2 onglets, déploiement)</td>
                    </tr>
                    <tr>
                        <td>Timeout réseau</td>
                        <td>Retry auto · <code>response:error</code></td>
                        <td>Feedback utilisateur via hook JS</td>
                    </tr>
                </tbody>
            </table>
        </div>
        <div class="code-split__col">
            <h3>ProductSearch — erreur Doctrine comme état</h3>
<pre><code class="language-php">#[AsLiveComponent]
final class ProductSearch
{
    use DefaultActionTrait;

    #[LiveProp(writable: true)]
    public string $query = '';

    public ?string $error = null;

    public function getResults(): array
    {
        try {
            return $this->products
                ->searchByName($this->query);
        } catch (\Exception) {
            $this->error = 'Recherche indisponible.';
            return [];
        }
    }
}</code></pre>
<pre><code class="language-twig">{% verbatim %}{% if error %}
    <p class="text-red-500">{{ error }}</p>
{% endif %}{% endverbatim %}</code></pre>
        </div>
    </div>
</section>
