{% import 'presentation/_macros.html.twig' as ui %}
{% import 'presentation/chapters/02-avant-symfony-ux/_macros.html.twig' as card %}

<section data-slide-id="02-stimulus">
    {{ ui.slide_header('2.6', 'Template + sprinkle de JS', 'Rendu serveur, comportement ajouté en Stimulus') }}

    <div class="code-split">
        <div class="code-split__col">
            <h3>Markup</h3>
<pre><code class="language-twig">{% verbatim %}<div data-controller="search"
     data-search-url-value="{{ path('app_search') }}">
    <input type="text"
           data-search-target="input"
           data-action="input->search#query">
    <ul data-search-target="results"></ul>
</div>{% endverbatim %}</code></pre>
        </div>

        <div class="code-split__col">
            <h3>Comportement</h3>
<pre><code class="language-javascript">import { Controller } from '@hotwired/stimulus';

export default class extends Controller {
    static targets = ['input', 'results'];
    static values = { url: String };

    async query() {
        const r = await fetch(
            `${this.urlValue}?q=${this.inputTarget.value}`
        );
        this.resultsTarget.innerHTML = await r.text();
    }
}</code></pre>
        </div>
    </div>

    {{ card.pros_cons(
        [
            '<strong>Vraie interactivité</strong> côté client',
            'Séparation markup / comportement claire',
        ],
        [
            '<strong>Double codebase</strong> : logique métier souvent dupliquée (PHP + JS)',
            'État client et état serveur divergent',
            'Un endpoint ad hoc et du boilerplate par comportement',
        ]
    ) }}

    {{ card.legitimate_uses([
        'Comportements purement client : toggler une classe, ouvrir un menu, copier dans le presse-papier',
        'Rôle résiduel de Stimulus dans Symfony UX — il ne disparaît pas, il est recadré',
    ]) }}
</section>
