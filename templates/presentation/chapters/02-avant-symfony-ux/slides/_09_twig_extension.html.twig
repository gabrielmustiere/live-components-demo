{% import 'presentation/chapters/02-avant-symfony-ux/_macros.html.twig' as ui %}

<section data-slide-id="02-twig-extension">
    {{ ui.slide_header('2.4', 'Twig extension', 'Une fonction Twig qui génère du HTML') }}

<pre class="r-stretch"><code class="language-php">final class UiExtension extends AbstractExtension
{
    public function getFunctions(): array
    {
        return [
            new TwigFunction('badge', [$this, 'renderBadge'], ['is_safe' => ['html']]),
        ];
    }

    public function renderBadge(string $label, string $color = 'gray'): string
    {
        return sprintf(
            '&lt;span class="badge badge-%s"&gt;%s&lt;/span&gt;',
            htmlspecialchars($color, ENT_QUOTES, 'UTF-8'),
            htmlspecialchars($label, ENT_QUOTES, 'UTF-8'),
        );
    }
}</code></pre>

<pre><code class="language-twig">{% verbatim %}{{ badge(user.status, 'success') }}{% endverbatim %}</code></pre>
</section>
