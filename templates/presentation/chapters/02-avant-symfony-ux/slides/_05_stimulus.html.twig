{% import 'presentation/chapters/02-avant-symfony-ux/_macros.html.twig' as ui %}

<section data-slide-id="02-stimulus">
    {{ ui.slide_header('2.4', 'Template + Stimulus', 'L\'interactivité par JS') }}

    <div class="code-split">
        <div class="code-split__col">
            <h3>Template</h3>
<pre><code class="language-twig">{% verbatim %}<div data-controller="search"
     data-search-url-value="{{ path('app_search') }}">
    <input data-search-target="input"
           data-action="input->search#query">
    <ul data-search-target="results"></ul>
</div>{% endverbatim %}</code></pre>
        </div>

        <div class="code-split__col">
            <h3>Controller JS</h3>
<pre><code class="language-javascript">export default class extends Controller {
    static targets = ['input', 'results'];
    static values = { url: String };

    async query() {
        const r = await fetch(
            `${this.urlValue}?q=${this.inputTarget.value}`);
        this.resultsTarget.innerHTML = await r.text();
    }
}</code></pre>
        </div>
    </div>

    {{ ui.pros_cons(
        [
            '<strong>Vraie interactivité</strong> côté client',
            'Séparation markup / comportement',
        ],
        [
            '<strong>Double codebase</strong> : logique dupliquée PHP ↔ JS',
            'État client ≠ état serveur → désynchronisation',
            'Un endpoint ad hoc par interaction + boilerplate à chaque comportement',
        ]
    ) }}

    {{ ui.verdict('Rôle résiduel légitime : comportements purement client (menu, toggle, clipboard) — mais plus la réponse à tout.') }}
</section>
