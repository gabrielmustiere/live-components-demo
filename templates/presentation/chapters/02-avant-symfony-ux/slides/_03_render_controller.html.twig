    {{ ui.slide_header('2.2', 'render(controller(...))', 'Le "composant" via sous-requête HTTP') }}

<pre><code class="language-twig">{% verbatim %}{{ render(controller('App\\Controller\\CartController::miniCart')) }}{% endverbatim %}</code></pre>

<pre><code class="language-php">public function miniCart(CartRepository $carts, Security $security): Response
{
    $cart = $carts->findCurrentFor($security->getUser());

    return $this->render('cart/_mini_cart.html.twig', [
        'itemCount' => $cart->count(),
        'total'     => $cart->total(),
    ]);
}</code></pre>

