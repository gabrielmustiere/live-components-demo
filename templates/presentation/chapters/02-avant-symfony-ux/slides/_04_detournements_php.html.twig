{% import 'presentation/chapters/02-avant-symfony-ux/_macros.html.twig' as ui %}

<section data-slide-id="02-detournements-php">
    {{ ui.slide_header('2.3', 'Détournements PHP', 'Twig extension & Form Type') }}

    <div class="code-split">
        <div class="code-split__col">
            <h3>Twig extension</h3>
<pre><code class="language-php">new TwigFunction('badge',
    [$this, 'renderBadge'],
    ['is_safe' => ['html']]
);

public function renderBadge(string $label, string $color): string
{
    return sprintf('&lt;span class="badge-%s"&gt;%s&lt;/span&gt;',
        $color, htmlspecialchars($label));
}</code></pre>
<pre><code class="language-twig">{% verbatim %}{{ badge(user.status, 'success') }}{% endverbatim %}</code></pre>
            <p><small>Helpers purs OK · <strong>pas</strong> des composants d'UI · HTML en string PHP, pas de slots.</small></p>
        </div>

        <div class="code-split__col">
            <h3>Form Type détourné</h3>
<pre><code class="language-php">final class TagPickerType extends AbstractType
{
    public function configureOptions(OptionsResolver $r): void
    {
        $r->setDefaults([
            'choices'  => [],
            'multiple' => true,
        ]);
    }

    public function getParent(): string
    {
        return ChoiceType::class;
    }
}</code></pre>
            <p><small>Props via <code>OptionsResolver</code> · <strong>champs de form uniquement</strong> — inutilisable pour Card, Modal, Sidebar.</small></p>
        </div>
    </div>

    {{ ui.verdict('Ça marche localement, mais ce n\'est pas un modèle composant généraliste.') }}
</section>
