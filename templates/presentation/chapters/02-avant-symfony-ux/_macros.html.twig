{#
    Macros locales au chapitre 02.
    `slide_header` vit dans presentation/_macros.html.twig — on ne le redéfinit pas ici.
#}

{# Deux colonnes "Ce que ça résout / Ce que ça ne résout pas". HTML autorisé via |raw. #}
{% macro pros_cons(pros = [], cons = []) %}
    <div class="pros-cons">
        {% if pros|length > 0 %}
            <div class="pros-cons__col pros-cons__col--pros">
                <h3>✅ Ce que ça résout</h3>
                <ul>
                    {% for item in pros %}<li>{{ item|raw }}</li>{% endfor %}
                </ul>
            </div>
        {% endif %}
        {% if cons|length > 0 %}
            <div class="pros-cons__col pros-cons__col--cons">
                <h3>❌ Ce que ça ne résout pas</h3>
                <ul>
                    {% for item in cons %}<li>{{ item|raw }}</li>{% endfor %}
                </ul>
            </div>
        {% endif %}
    </div>
{% endmacro %}

{# Encart ambre de conclusion pour chaque approche. #}
{% macro verdict(text) %}
    <blockquote class="verdict">{{ text|raw }}</blockquote>
{% endmacro %}

{# Encart vert "cas d'usage encore pertinents aujourd'hui". #}
{% macro legitimate_uses(items) %}
    <div class="legitimate">
        <h3>🎯 Cas d'usage légitimes</h3>
        <ul>
            {% for item in items %}<li>{{ item|raw }}</li>{% endfor %}
        </ul>
    </div>
{% endmacro %}
