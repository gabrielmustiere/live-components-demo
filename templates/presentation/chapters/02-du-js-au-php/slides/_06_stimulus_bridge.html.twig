{% import 'presentation/_macros.html.twig' as ui %}

<section data-slide-id="02-stimulus-bridge">
    {{ ui.slide_header('2.5', 'Clé en main') }}

    <p>
        Live Components arrive avec le <strong>Stimulus bridge</strong> via
        <strong>AssetMapper</strong> et une recette <strong>Flex</strong>. Tout est câblé côté front.
    </p>

    <div class="r-stretch mermaid-wrapper">
        <pre class="mermaid">
flowchart LR
    INSTALL["composer require<br/>symfony/ux-live-component"]
    MAGIC(["AssetMapper<br/>+ Stimulus bridge"])
    READY["Live Components<br/>prêts à l'emploi"]

    INSTALL --> MAGIC --> READY

    classDef step fill:#312e81,stroke:#818cf8,stroke-width:2px,color:#e0e7ff;
    classDef bridge fill:#6366f1,stroke:#c7d2fe,stroke-width:2px,color:#ffffff;
    classDef result fill:#4338ca,stroke:#a5b4fc,stroke-width:2px,color:#eef2ff;

    class INSTALL step;
    class MAGIC bridge;
    class READY result;
        </pre>
    </div>

    <blockquote class="verdict"><strong>Zéro <code>npm install</code>, zéro config JS : une commande et c'est en place.</strong></blockquote>
</section>
