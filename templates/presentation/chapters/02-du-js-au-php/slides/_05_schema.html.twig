{% import 'presentation/_macros.html.twig' as ui %}

<section data-slide-id="02-schema">
    {{ ui.slide_header('2.4', 'Une architecture, une commande') }}

    <p>
        Tout cet assemblage arrive par un seul
        <code>composer require symfony/ux-live-component</code> —
        <strong>AssetMapper</strong> et le <strong>bridge Stimulus</strong> sont câblés par la recette Flex.
    </p>

    <div class="r-stretch mermaid-wrapper">
        <pre class="mermaid">
flowchart TB
    subgraph PHP["&nbsp;&nbsp;&nbsp;Php / Twig&nbsp;&nbsp;&nbsp;"]
        direction TB
        LC["Live Components"]
        TC["Twig Components"]
        LC --> TC
    end

    BRIDGE(["Stimulus bridge"])

    subgraph JS["&nbsp;&nbsp;&nbsp;Javascript&nbsp;&nbsp;&nbsp;"]
        direction TB
        STIM["Stimulus"]
    end

    subgraph BUILD["&nbsp;&nbsp;&nbsp;Build / Assets&nbsp;&nbsp;&nbsp;"]
        direction TB
        AM["AssetMapper"]
    end

    LC --> BRIDGE --> JS --> BUILD

    classDef php fill:#312e81,stroke:#818cf8,stroke-width:2px,color:#e0e7ff;
    classDef live fill:#4338ca,stroke:#a5b4fc,stroke-width:2px,color:#eef2ff;
    classDef bridge fill:#6366f1,stroke:#c7d2fe,stroke-width:2px,color:#ffffff;
    classDef infra fill:#1f2937,stroke:#9ca3af,stroke-width:1.5px,color:#f3f4f6;

    class TC php;
    class LC live;
    class BRIDGE bridge;
    class STIM,AM infra;
        </pre>
    </div>

    <blockquote class="verdict"><strong>Zéro <code>npm install</code>, zéro config JS : une commande et c'est en place.</strong></blockquote>
</section>
