{% extends 'demo/layout.html.twig' %}

{% block demo_page_title %}ProductCard Twig Component{% endblock %}
{% block demo_title %}ProductCard{% endblock %}

{% block demo_body %}
    <h1 class="text-3xl font-bold text-gray-900">Twig Component <code>ProductCard</code></h1>
    <p class="mt-2 text-gray-600">
        Composant statique avec un service injecté (<code>PriceFormatter</code>) et une méthode exposée via <code>this.formattedPrice</code>.
    </p>

    <div class="mt-10 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {% for product in products %}
            <twig:ProductCard :product="product" />
        {% endfor %}
    </div>

    <twig:SourceViewer :files="[
        'src/Twig/Components/ProductCard.php',
        'templates/components/ProductCard.html.twig',
        'src/Demo/PriceFormatter.php',
    ]" />
{% endblock %}
