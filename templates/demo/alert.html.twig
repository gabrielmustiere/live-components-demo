{% extends 'demo/layout.html.twig' %}

{% block demo_page_title %}Alert Twig Component{% endblock %}
{% block demo_title %}Alert{% endblock %}

{% block demo_body %}
    <h1 class="text-3xl font-bold text-gray-900">Twig Component <code>Alert</code></h1>
    <p class="mt-2 text-gray-600">
        Composant statique minimal : trois props publiques, un template, aucune logique côté client.
    </p>

    <div class="mt-10 space-y-4 rounded-xl border border-gray-200 bg-white p-8 shadow-sm">
        <twig:Alert message="Bienvenue ! C'est l'alerte de base, type 'info'." type="info" />
        <twig:Alert message="Votre profil a bien été mis à jour." type="success" />
        <twig:Alert message="Votre session expire dans 5 minutes." type="warning" :dismissible="true" />
        <twig:Alert message="Impossible de contacter le serveur." type="error" :dismissible="true" />
    </div>

    <twig:SourceViewer :files="[
        'src/Twig/Components/Alert.php',
        'templates/components/Alert.html.twig',
    ]" />
{% endblock %}
