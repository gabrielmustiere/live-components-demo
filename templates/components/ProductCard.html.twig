<article {{ attributes.defaults({
    class: 'relative flex flex-col gap-3 rounded-xl border border-gray-200 bg-white p-5 shadow-sm transition hover:shadow-md',
}) }}>
    {% if showBadge and product.new %}
        <span class="absolute right-4 top-4 rounded-full bg-indigo-600 px-2.5 py-0.5 text-xs font-semibold text-white">
            Nouveau
        </span>
    {% endif %}

    <h3 class="pr-16 text-base font-semibold text-gray-900">{{ product.name }}</h3>

    <p class="text-2xl font-bold tabular-nums text-indigo-600">{{ this.formattedPrice }}</p>
</article>
